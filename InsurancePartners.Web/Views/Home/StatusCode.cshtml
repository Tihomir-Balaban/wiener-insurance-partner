@model int

@{
    ViewData["Title"] = $"Status Code {Model}";

    var message = Model switch
    {
        404 => "The page or resource you requested could not be found.",
        403 => "You do not have permission to access this resource.",
        500 => "The server encountered an error while processing your request.",
        _ => "The request could not be completed."
    };
}

<div class="card shadow-sm">
    <div class="card-body">
        <h1 class="h4">Status Code @Model</h1>

        <p class="mb-3">
            @message
        </p>

        <a asp-controller="Partners" asp-action="Index" class="btn btn-primary">
            Back to Partners
        </a>
    </div>
</div>