@model IReadOnlyList<PartnerListItemViewModel>

@{
    ViewData["Title"] = "Partners";

    int? highlightId = null;

    if (ViewBag.HighlightId is int id)
    {
        highlightId = id;
    }
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Insurance Partners</h1>
        <p class="text-muted mb-0">Manage insurance company partners and their policies.</p>
    </div>

    <a asp-controller="Partners" asp-action="Create" class="btn btn-primary">
        Add Partner
    </a>
</div>

<div id="pageAlertContainer"></div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @successMessage
        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
            <span aria-hidden="true">&times;</span>
        </button>
    </div>
}

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @errorMessage
        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
            <span aria-hidden="true">&times;</span>
        </button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-header bg-white">
        <strong>Partner List</strong>
    </div>

    <div class="card-body p-0">
        @if (Model.Count == 0)
        {
            <div class="p-4 text-center text-muted">
                No partners have been added yet.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0">
                    <thead class="thead-light">
                    <tr>
                        <th>Full Name</th>
                        <th>Partner Number</th>
                        <th>Croatian PIN / OIB</th>
                        <th>Partner Type</th>
                        <th>Created At UTC</th>
                        <th>Foreign</th>
                        <th>Gender</th>
                        <th class="text-right">Policies</th>
                        <th class="text-right">Total Amount</th>
                        <th class="text-right">Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var partner in Model)
                    {
                        var rowClass = highlightId == partner.Id
                            ? "table-warning font-weight-bold"
                            : string.Empty;

                        var tableRowClass = $"js-partner-row {rowClass}".Trim();

                        var fullName = partner.IsMarked
                            ? $"* {partner.FullName}"
                            : partner.FullName;

                        <tr class="@tableRowClass" data-partner-id="@partner.Id">
                            <td>
                                <span class="partner-full-name" data-base-name="@partner.FullName">@fullName</span>
                            </td>
                            <td>@partner.PartnerNumber</td>
                            <td>@(partner.CroatianPIN ?? "-")</td>
                            <td>@partner.PartnerTypeName</td>
                            <td>@partner.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@(partner.IsForeign ? "Yes" : "No")</td>
                            <td>@partner.Gender</td>
                            <td class="text-right partner-policy-count">@partner.PolicyCount</td>
                            <td class="text-right partner-total-policy-amount">
                                @partner.TotalPolicyAmount.ToString("N2")
                            </td>
                            <td class="text-right">
                                <div class="btn-group btn-group-sm" role="group">
                                    <button
                                        type="button"
                                        class="btn btn-outline-info js-partner-details"
                                        data-partner-id="@partner.Id">
                                        Details
                                    </button>

                                    <button
                                        type="button"
                                        class="btn btn-outline-success js-add-policy"
                                        data-partner-id="@partner.Id"
                                        data-partner-name="@partner.FullName">
                                        Add Policy
                                    </button>

                                    <a
                                        asp-controller="Partners"
                                        asp-action="Edit"
                                        asp-route-id="@partner.Id"
                                        class="btn btn-outline-primary">
                                        Edit
                                    </a>

                                    <button
                                        type="button"
                                        class="btn btn-outline-danger js-delete-partner"
                                        data-partner-id="@partner.Id"
                                        data-partner-name="@partner.FullName">
                                        Delete
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
<div
    class="modal fade"
    id="partnerDetailsModal"
    tabindex="-1"
    role="dialog"
    aria-labelledby="partnerDetailsModalLabel"
    aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content" id="partnerDetailsModalContent">
            <div class="modal-body text-center p-5">
                Loading...
            </div>
        </div>
    </div>
</div>
<div
    class="modal fade"
    id="deletePartnerModal"
    tabindex="-1"
    role="dialog"
    aria-labelledby="deletePartnerModalLabel"
    aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <form id="deletePartnerForm" method="post">
                @Html.AntiForgeryToken()

                <div class="modal-header">
                    <h5 class="modal-title" id="deletePartnerModalLabel">
                        Delete Partner
                    </h5>

                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>

                <div class="modal-body">
                    <p class="mb-2">
                        Are you sure you want to delete this partner?
                    </p>

                    <p class="font-weight-bold mb-0" id="deletePartnerName"></p>

                    <small class="text-muted">
                        This is a soft delete. The partner will be hidden from the application but kept in the database.
                    </small>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-dismiss="modal">
                        Cancel
                    </button>

                    <button type="submit" class="btn btn-danger">
                        Delete Partner
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
<div
    class="modal fade"
    id="addPolicyModal"
    tabindex="-1"
    role="dialog"
    aria-labelledby="addPolicyModalLabel"
    aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <form id="addPolicyForm" method="post" action="/Policies/Create">
                @Html.AntiForgeryToken()

                <input type="hidden" id="addPolicyId" name="Id"/>
                <input type="hidden" id="addPolicyPartnerId" name="PartnerId"/>
                <input type="hidden" id="addPolicyRowVersion" name="RowVersion"/>

                <div class="modal-header">
                    <div>
                        <h5 class="modal-title" id="addPolicyModalLabel">
                            Add Policy
                        </h5>
                        <small class="text-muted" id="addPolicyPartnerName"></small>
                    </div>

                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>

                <div class="modal-body">
                    <div id="addPolicyErrors"></div>

                    <div class="form-group">
                        <label for="addPolicyNumber">Policy Number</label>
                        <input
                            type="text"
                            class="form-control"
                            id="addPolicyNumber"
                            name="PolicyNumber"
                            maxlength="15"
                            autocomplete="off"/>
                        <small class="form-text text-muted">
                            Alphanumeric, 10 to 15 characters, unique.
                        </small>
                    </div>

                    <div class="form-group">
                        <label for="addPolicyAmount">Policy Amount</label>
                        <input
                            type="number"
                            class="form-control"
                            id="addPolicyAmount"
                            name="PolicyAmount"
                            min="0.01"
                            step="0.01"/>
                        <small class="form-text text-muted">
                            Amount must be greater than 0 HRK.
                        </small>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-dismiss="modal">
                        Cancel
                    </button>

                    <button type="submit" class="btn btn-success" id="addPolicySubmitButton">
                        Save Policy
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
<div
    class="modal fade"
    id="deletePolicyModal"
    tabindex="-1"
    role="dialog"
    aria-labelledby="deletePolicyModalLabel"
    aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <form id="deletePolicyForm" method="post">
                @Html.AntiForgeryToken()

                <div class="modal-header">
                    <h5 class="modal-title" id="deletePolicyModalLabel">
                        Delete Policy
                    </h5>

                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>

                <div class="modal-body">
                    <div id="deletePolicyErrors"></div>

                    <p class="mb-2">
                        Are you sure you want to delete this policy?
                    </p>

                    <p class="font-weight-bold mb-0" id="deletePolicyNumber"></p>

                    <small class="text-muted">
                        This is a soft delete. The policy will be hidden from the application but kept in the database.
                    </small>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-dismiss="modal">
                        Cancel
                    </button>

                    <button type="submit" class="btn btn-danger">
                        Delete Policy
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    <script src="~/js/partners.js" asp-append-version="true"></script>
}