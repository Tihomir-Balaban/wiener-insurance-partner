@model PartnerDetailsViewModel

<div class="modal-header">
    <div>
        <h5 class="modal-title">
            Partner Details
        </h5>
        <small class="text-muted">@Model.FullName</small>
    </div>

    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
        <span aria-hidden="true">&times;</span>
    </button>
</div>

<div class="modal-body">
    @if (Model.IsMarked)
    {
        <div class="alert alert-warning mb-4">
            This partner is marked because they have at least 5 policies or a total policy amount greater than 5,000 HRK.
        </div>
    }

    <h6 class="text-uppercase text-muted mb-3">Partner Information</h6>

    <dl class="row mb-4">
        <dt class="col-sm-4">Full Name</dt>
        <dd class="col-sm-8">@Model.FullName</dd>

        <dt class="col-sm-4">Address</dt>
        <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.Address) ? "-" : Model.Address)</dd>

        <dt class="col-sm-4">Partner Number</dt>
        <dd class="col-sm-8">@Model.PartnerNumber</dd>

        <dt class="col-sm-4">Croatian PIN / OIB</dt>
        <dd class="col-sm-8">@(Model.CroatianPIN ?? "-")</dd>

        <dt class="col-sm-4">Partner Type</dt>
        <dd class="col-sm-8">@Model.PartnerTypeName</dd>

        <dt class="col-sm-4">Created At UTC</dt>
        <dd class="col-sm-8">@Model.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm:ss")</dd>

        <dt class="col-sm-4">Created By User</dt>
        <dd class="col-sm-8">@Model.CreateByUser</dd>

        <dt class="col-sm-4">Foreign</dt>
        <dd class="col-sm-8">@(Model.IsForeign ? "Yes" : "No")</dd>

        <dt class="col-sm-4">External Code</dt>
        <dd class="col-sm-8">@Model.ExternalCode</dd>

        <dt class="col-sm-4">Gender</dt>
        <dd class="col-sm-8">@Model.Gender</dd>
    </dl>

    <h6 class="text-uppercase text-muted mb-3">Policy Summary</h6>

    <dl class="row mb-4">
        <dt class="col-sm-4">Policy Count</dt>
        <dd class="col-sm-8">@Model.PolicyCount</dd>

        <dt class="col-sm-4">Total Policy Amount</dt>
        <dd class="col-sm-8">@Model.TotalPolicyAmount.ToString("N2") HRK</dd>

        <dt class="col-sm-4">Marked</dt>
        <dd class="col-sm-8">@(Model.IsMarked ? "Yes" : "No")</dd>
    </dl>

    <h6 class="text-uppercase text-muted mb-3">Policies</h6>

    @if (Model.Policies.Count == 0)
    {
        <div class="text-muted">
            This partner has no policies.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm table-striped mb-0">
                <thead class="thead-light">
                <tr>
                    <th>Policy Number</th>
                    <th class="text-right">Amount</th>
                    <th>Created At UTC</th>
                    <th class="text-right">Actions</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var policy in Model.Policies)
                {
                    <tr data-policy-id="@policy.Id" data-policy-number="@policy.PolicyNumber">
                        <td>@policy.PolicyNumber</td>
                        <td class="text-right">@policy.PolicyAmount.ToString("N2")</td>
                        <td>@policy.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                        <td class="text-right">
                            <div class="btn-group btn-group-sm" role="group">
                                <button
                                    type="button"
                                    class="btn btn-outline-primary js-edit-policy mr-2"
                                    data-policy-id="@policy.Id">
                                    Edit
                                </button>

                                <button
                                    type="button"
                                    class="btn btn-outline-danger js-delete-policy"
                                    data-policy-id="@policy.Id"
                                    data-policy-number="@policy.PolicyNumber">
                                    Delete
                                </button>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>

<div class="modal-footer">
    <button type="button" class="btn btn-secondary" data-dismiss="modal">
        Close
    </button>
</div>